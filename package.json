{
  "name": "sniffmail",
  "version": "1.0.6",
  "type": "module",
  "description": "Email validation library that detects disposable/burner email addresses and verifies mailbox existence",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scrape": "npx tsx scripts/scrape-domains.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sniffmail/sniffmail.git"
  },
  "homepage": "https://sniffmail.io",
  "bugs": {
    "url": "https://github.com/sniffmail/sniffmail/issues"
  },
  "keywords": [
    "email",
    "validation",
    "email-validation",
    "email-validator",
    "disposable",
    "disposable-email",
    "burner",
    "temporary-email",
    "temp-mail",
    "spam",
    "anti-spam",
    "smtp",
    "smtp-verification",
    "verification",
    "mailbox-verification",
    "mx-records",
    "email-deliverability",
    "bounce-prevention",
    "fraud-prevention",
    "sniffmail"
  ],
  "author": "Sniffmail <hello@sniffmail.io>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-email-verifier": "^4.0.0",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "puppeteer": "^21.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "ioredis": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
